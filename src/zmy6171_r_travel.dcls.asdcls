@EndUserText.label: 'Data Model Access Control'
@MappingRole: true
define role ZMY6171_R_TRAVEL {
    grant 
        select
            on
                ZMY6171_R_TRAVEL
                    where
                        (AgencyId) = aspect pfcg_auth(/LRN/AGCY, /LRN/AGCY, ACTVT = '03');
                        
}
