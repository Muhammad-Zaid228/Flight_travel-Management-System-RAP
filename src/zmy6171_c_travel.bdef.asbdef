projection;
strict ( 2 );

use draft;

define behavior for ZMY6171_C_Travel //alias <alias_name>
use etag
{
  use create;
  use update;
  use delete;

  use association _TravelItem { create; with draft; }

  use action cancel_travel;

  // Draft Actions
  use action Edit;
  use action Activate;
  use action Discard;
  use action Prepare;
  use action Resume;
}


define behavior for ZMY6171_C_TRAVELITEM
use etag
{
use update;
use delete;
use association _Travel { with draft; }
}